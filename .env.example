# ============================================================
# Neura Tech AI — environment variables
# Copy this file to .env.local and fill in your values.
# ============================================================

# ---------- AI Gateway ----------
# Base URL of your running LiteLLM proxy/gateway.
# The frontend NEVER talks to this directly — only the Next.js
# API routes in app/api/* do.
LITELLM_BASE_URL=http://localhost:4000
# Optional — only needed if you've enabled auth on your LiteLLM instance.
LITELLM_API_KEY=

# ---------- Database ----------
# Any Postgres connection string works (Supabase, Neon, Railway, RDS, local).
DATABASE_URL=postgresql://user:password@localhost:5432/neuratech

# ---------- Auth (NextAuth v5 / Auth.js) ----------
# Generate with: npx auth secret
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# ---------- Billing (Stripe) ----------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the "Pro" monthly subscription (from your Stripe Dashboard → Products)
STRIPE_PRICE_ID_PRO=price_...
# Price IDs for the other paid tiers
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_BUSINESS=price_...

# ---------- Admin access ----------
# Comma-separated emails that are auto-promoted to ADMIN on their next
# sign-in (Google, GitHub, or email/password — any of them work).
# See lib/admin-config.ts for details, including how existing admins can
# promote other users from /admin/users without touching this file.
ADMIN_EMAILS=you@gmail.com

# ---------- Hugging Face model sync ----------
# Optional — only needed to sync private/gated HF repos. Public model
# metadata syncs without a token.
HF_TOKEN=

# ---------- Cron ----------
# Shared secret so a scheduled job (e.g. Vercel Cron) can trigger
# POST /api/huggingface/sync without a user session.
CRON_SECRET=
